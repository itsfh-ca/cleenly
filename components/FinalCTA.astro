---

---

<section
  class="py-20 bg-linear-to-br from-primary to-primary/90 relative overflow-hidden"
>
  <!-- Decorative circles -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute -top-24 -right-24 w-80 h-80 bg-white/10 rounded-full">
    </div>
    <div
      class="absolute -bottom-20 -left-20 w-64 h-64 bg-white/10 rounded-full"
    >
    </div>
  </div>

  <div class="relative max-w-3xl mx-auto px-4 sm:px-6 text-center">
    <p
      class="text-primary-foreground/70 font-semibold text-sm uppercase tracking-widest mb-4"
    >
      Ready to Get Started?
    </p>

    <h2
      class="text-4xl md:text-5xl font-semibold text-white mb-6 leading-tight tracking-tight"
    >
      Book Your Cleaning Today
    </h2>

    <p
      class="text-primary-foreground/80 text-lg mb-10 max-w-xl mx-auto leading-relaxed"
    >
      Join hundreds of happy customers across Surrey, White Rock, and Langley.
      Same-day availability. 100% satisfaction guaranteed.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="#quote"
        class="inline-flex items-center justify-center gap-2 bg-white text-primary font-semibold px-8 py-4 rounded-2xl hover:bg-white/90 transition-all duration-200 shadow-xl hover:shadow-2xl hover:-translate-y-0.5 text-base"
      >
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"
          ></path>
        </svg>
        Get Instant Quote
      </a>

      <a
        href="tel:+16045550192"
        class="inline-flex items-center justify-center gap-2 bg-transparent text-white font-semibold px-8 py-4 rounded-2xl border-2 border-white/50 hover:border-white hover:bg-white/10 transition-all duration-200 text-base"
      >
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path
            d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8 19.79 19.79 0 01.22 2.18 2 2 0 012.22 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 7.09a16 16 0 006 6l.56-.56a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"
          ></path>
        </svg>
        (604) 555-0192
      </a>
    </div>

    <!-- Trust Strip -->
    <div
      class="mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-3"
    >
      {
        [
          "Fully Insured",
          "200+ Happy Customers",
          "Same-Day Available",
          "5-Star Reviews",
        ].map((item) => (
          <div class="flex items-center gap-2 text-primary-foreground/75 text-sm">
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="3"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <polyline points="20 6 9 17 4 12" />
            </svg>
            <span>{item}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>

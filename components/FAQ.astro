---
const faqs = [
  {
    q: "How do I get a quote?",
    a: "Fill out our quick quote form above with your home size and contact info. We'll confirm your exact price within 15 minutes during business hours. You can also call us directly at (604) 555-0192.",
  },
  {
    q: "Do I need to be home during the cleaning?",
    a: "No! Most customers leave a key or access code. We're fully insured and all cleaners are background-checked. If you prefer to be home, that's totally fine too.",
  },
  {
    q: "What's included in a Standard Clean?",
    a: "Standard cleaning includes dusting all surfaces, vacuuming and mopping all floors, cleaning bathrooms (toilet, sink, tub/shower), kitchen wipe-down (counters, stovetop, exterior of appliances), and general tidying. For a full deep clean including inside appliances and detailed areas, see our Deep Clean option.",
  },
  {
    q: "Do you bring your own supplies and equipment?",
    a: "Yes! We bring everything needed — professional-grade cleaning products, vacuums, mops, and more. If you have a specific product preference or sensitivity, let us know and we'll accommodate.",
  },
  {
    q: "What if I'm not satisfied with the cleaning?",
    a: "We offer a 100% satisfaction guarantee. If any area doesn't meet your expectations, contact us within 24 hours and we'll return to re-clean it at no charge. Your happiness is our priority.",
  },
  {
    q: "Can I book a recurring cleaning?",
    a: "Absolutely! Many of our customers book weekly, bi-weekly, or monthly recurring cleanings. We offer discounts for regular bookings — ask us about it when you get your quote.",
  },
  {
    q: "How do you vet your cleaners?",
    a: "Every cleaner goes through a thorough background check, reference check, and in-person training before working with us. We only send cleaners we'd be comfortable having in our own homes.",
  },
  {
    q: "Do you service apartments and condos?",
    a: "Yes! We clean apartments, condos, townhouses, and single-family homes. Just let us know the type and size of your home when booking.",
  },
];
---

<section id="faq" class="py-16 bg-white">
  <div class="max-w-3xl mx-auto px-4 sm:px-6">
    <!-- Header -->
    <div class="text-center mb-12">
      <p
        class="text-primary font-semibold text-sm uppercase tracking-widest mb-3"
      >
        FAQ
      </p>
      <h2
        class="text-4xl md:text-5xl font-semibold tracking-tight text-slate-900 mb-4"
      >
        Frequently Asked Questions
      </h2>
      <p class="text-slate-500">Everything you need to know before booking.</p>
    </div>

    <!-- FAQ Accordion -->
    <div class="space-y-3" id="faq-accordion">
      {
        faqs.map((faq, index) => (
          <div class="border border-slate-200 rounded-2xl overflow-hidden bg-white">
            <button
              class="faq-button w-full flex items-center justify-between gap-4 px-6 py-5 text-left hover:bg-slate-50 transition-colors"
              data-index={index}
            >
              <div class="flex items-center gap-4">
                <span class="text-primary font-bold text-sm w-6 shrink-0">
                  {(index + 1).toString().padStart(2, "0")}
                </span>
                <span class="font-semibold text-slate-800">{faq.q}</span>
              </div>
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="faq-chevron shrink-0 text-slate-400 transition-transform duration-300"
              >
                <polyline points="6 9 12 15 18 9" />
              </svg>
            </button>

            <div class="faq-answer hidden px-6 pb-6 text-slate-600 leading-relaxed text-[15px]">
              {faq.a}
            </div>
          </div>
        ))
      }
    </div>

    <!-- Still have questions -->
    <div class="mt-12 bg-slate-50 rounded-3xl p-8 text-center">
      <p class="text-slate-600 mb-4">Still have questions?</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="tel:+16045550192"
          class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground hover:bg-primary/90 transition-colors font-medium px-7 py-3.5 rounded-2xl"
        >
          Call (604) 555-0192
        </a>
        <a
          href="mailto:hello@cleenly.ca"
          class="inline-flex items-center justify-center border border-slate-300 hover:bg-white hover:border-slate-400 transition-colors font-medium px-7 py-3.5 rounded-2xl"
        >
          Email Us
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll(".faq-button").forEach((button) => {
    button.addEventListener("click", () => {
      const answer = button.nextElementSibling;
      const chevron = button.querySelector(".faq-chevron");

      if (!answer) return;
      const isOpen = !answer.classList.contains("hidden");

      // Close all others
      document.querySelectorAll(".faq-answer").forEach((ans) => {
        if (ans !== answer) {
          ans.classList.add("hidden");
        }
      });
      document.querySelectorAll(".faq-chevron").forEach((ch) => {
        if (ch !== chevron) ch.classList.remove("rotate-180");
      });

      // Toggle current
      answer.classList.toggle("hidden");
      if (chevron) {
        chevron.classList.toggle("rotate-180");
      }
    });
  });
</script>

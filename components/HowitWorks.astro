---
const steps = [
  {
    step: '01',
    title: 'Get a Quote',
    description: 'Fill out our quick form or give us a call. We\'ll confirm your price within 15 minutes.',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>`
  },
  {
    step: '02',
    title: 'Pick a Time',
    description: 'Choose a time that works for you — including same-day slots. We work around your schedule.',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`
  },
  {
    step: '03',
    title: 'We Clean',
    description: 'Our vetted cleaners arrive on time and transform your home. You can stay or leave — it\'s up to you.',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`
  },
]
---

<section class="py-16 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <!-- Header -->
    <div class="text-center mb-12">
      <p class="text-primary font-semibold text-sm uppercase tracking-widest mb-3">
        How It Works
      </p>
      <h2 class="text-4xl md:text-5xl font-semibold tracking-tight text-slate-900 mb-4">
        Clean Home in 3 Simple Steps
      </h2>
      <p class="text-slate-500">It really is this easy.</p>
    </div>

    <!-- Steps -->
    <div class="grid md:grid-cols-3 gap-10 md:gap-8 relative">
      <!-- Connecting Line -->
      <div class="hidden md:block absolute top-12 left-[calc(16.67%+1.5rem)] right-[calc(16.67%+1.5rem)] h-px bg-slate-200" />

      {steps.map((step, index) => (
        <div class="flex flex-col items-center text-center relative group">
          <!-- Icon Circle -->
          <div class="relative mb-8">
            <div class="w-20 h-20 bg-primary/10 border-2 border-primary/20 rounded-full flex items-center justify-center text-primary transition-all group-hover:scale-105">
              <div set:html={step.icon} />
            </div>
            
            <!-- Step Number -->
            <div class="absolute -top-1.5 -right-1.5 w-8 h-8 bg-primary text-white rounded-full flex items-center justify-center text-sm font-bold shadow-md">
              {index + 1}
            </div>
          </div>

          <!-- Content -->
          <h3 class="font-semibold text-2xl text-slate-900 mb-3">
            {step.title}
          </h3>
          <p class="text-slate-600 text-[15px] leading-relaxed max-w-xs">
            {step.description}
          </p>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-14">
      <a
        href="#quote"
        class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground hover:bg-primary/90 transition-colors font-semibold text-lg px-10 py-4 rounded-2xl shadow-lg shadow-primary/20"
      >
        Get Started Today
      </a>
    </div>
  </div>
</section>
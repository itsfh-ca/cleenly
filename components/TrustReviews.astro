---
const reviews = [
  {
    name: "Sarah M.",
    location: "Surrey, BC",
    rating: 5,
    text: "Cleenly did an incredible deep clean of our 3-bedroom home before we moved in. Every corner was spotless. Highly recommend!",
    avatar: "SM",
    color: "bg-purple-100 text-purple-700",
  },
  {
    name: "David L.",
    location: "White Rock, BC",
    rating: 5,
    text: "I've tried 3 different cleaning services and Cleenly is by far the best. They're on time, thorough, and the price is unbeatable.",
    avatar: "DL",
    color: "bg-primary/10 text-primary",
  },
  {
    name: "Amanda K.",
    location: "Langley, BC",
    rating: 5,
    text: "Used them for our Airbnb between guests. Super quick turnaround, great attention to detail. My guests always comment on how clean it is.",
    avatar: "AK",
    color: "bg-green-100 text-green-700",
  },
  {
    name: "Tom R.",
    location: "Surrey, BC",
    rating: 5,
    text: "Booked a same-day clean and they showed up on time with everything needed. The team was friendly and professional. 10/10.",
    avatar: "TR",
    color: "bg-orange-100 text-orange-700",
  },
];
---

<section id="reviews" class="py-16 bg-slate-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <!-- Header -->
    <div class="text-center mb-12">
      <p class="text-primary font-semibold text-sm uppercase tracking-widest mb-3">
        Customer Reviews
      </p>
      <h2 class="text-4xl md:text-5xl font-semibold tracking-tight text-slate-900 mb-4">
        What Our Customers Say
      </h2>
      <div class="flex items-center justify-center gap-3">
        <!-- Stars -->
        <div class="flex gap-0.5">
          {Array.from({ length: 5 }).map((_, i) => (
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="#f59e0b"
              stroke="#f59e0b"
              stroke-width="1"
            >
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
            </svg>
          ))}
        </div>
        <span class="text-slate-600 text-sm">
          <strong class="text-slate-800">4.9 / 5</strong> — 200+ verified reviews
        </span>
      </div>
    </div>

    <!-- Reviews Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {reviews.map((review) => (
        <div
          class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow flex flex-col h-full"
        >
          <!-- Stars -->
          <div class="flex gap-0.5 mb-4">
            {Array.from({ length: review.rating }).map((_, i) => (
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="#f59e0b"
                stroke="#f59e0b"
                stroke-width="1"
              >
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
              </svg>
            ))}
          </div>

          <!-- Review Text -->
          <p class="text-slate-600 text-[15px] leading-relaxed flex-1">
            “{review.text}”
          </p>

          <!-- Author -->
          <div class="flex items-center gap-3 pt-6 mt-auto border-t border-slate-100">
            <div
              class={`w-9 h-9 rounded-full flex items-center justify-center text-sm font-bold shrink-0 ${review.color}`}
            >
              {review.avatar}
            </div>
            <div>
              <p class="font-semibold text-slate-900 text-sm">
                {review.name}
              </p>
              <p class="text-xs text-slate-500">{review.location}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Google Verified Badge -->
    <div class="mt-10 flex justify-center">
      <div class="inline-flex items-center gap-2.5 bg-white border border-slate-200 rounded-2xl px-6 py-3.5 shadow-sm text-sm text-slate-600">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
          <path
            d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
            fill="#4285F4"
          />
          <path
            d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
            fill="#34A853"
          />
          <path
            d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
            fill="#FBBC05"
          />
          <path
            d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
            fill="#EA4335"
          />
        </svg>
        <span class="font-medium">Verified on Google · 4.9 ★</span>
      </div>
    </div>
  </div>
</section>
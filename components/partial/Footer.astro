---
import { getSiteMenu, getSiteSettings } from "@/lib/consts";
import { Phone } from "lucide-react";
const menu = await getSiteMenu();
const site = await getSiteSettings();
const formatPhone = (phone: string) => {
  const cleaned = phone.replace(/\D/g, "");
  return cleaned.replace(/^(\d{3})(\d{3})(\d{4})$/, "($1) $2-$3");
};
const formattedPhone = formatPhone(site.phone ? site.phone : "");
const SiteName = site.siteName.split(" ");
---

<footer class="bg-slate-900 text-slate-400">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8 mb-10">
      <!-- Brand Column -->
      <div class="lg:col-span-2">
        <div class="flex items-center gap-2 mb-4">
          {
            site.logo && (
              <img
                src={site.logo.url}
                alt={site.siteName}
                class="w-5 h-5 object-contain"
              />
            )
          }
          <span class="font-display text-2xl text-white">
            {SiteName[0]}
            <span class="text-primary">{SiteName[1]}</span>
          </span>
        </div>

        <p class="text-slate-500 text-sm leading-relaxed max-w-xs mb-6">
          Professional residential cleaning services for Surrey, White Rock,
          Langley and surrounding areas. Trusted, insured, and satisfaction
          guaranteed.
        </p>

        <div class="space-y-3">
          <a
            href={`tel:${site.phone}`}
            class="flex items-center gap-2 text-sm hover:text-white transition-colors"
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8 19.79 19.79 0 01.22 2.18 2 2 0 012.22 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 7.09a16 16 0 006 6l.56-.56a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"
              ></path>
            </svg>
            {formattedPhone}
          </a>

          <a
            href="mailto:hello@cleenly.ca"
            class="flex items-center gap-2 text-sm hover:text-white transition-colors"
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
              ></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
            hello@cleenly.ca
          </a>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h4 class="text-white font-semibold text-sm mb-4">Services</h4>
        <ul class="space-y-2.5 text-sm">
          <li>
            <a href="#services" class="hover:text-white transition-colors"
              >Standard Cleaning</a
            >
          </li>
          <li>
            <a href="#services" class="hover:text-white transition-colors"
              >Deep Cleaning</a
            >
          </li>
          <li>
            <a href="#services" class="hover:text-white transition-colors"
              >Move-In / Move-Out</a
            >
          </li>
          <li>
            <a href="#services" class="hover:text-white transition-colors"
              >Airbnb Cleaning</a
            >
          </li>
          <li>
            <a href="#services" class="hover:text-white transition-colors"
              >Office Cleaning</a
            >
          </li>
        </ul>
      </div>

      <!-- Service Areas -->
      <div>
        <h4 class="text-white font-semibold text-sm mb-4">Service Areas</h4>
        <ul class="space-y-2.5 text-sm">
          <li><span class="text-slate-400">Surrey, BC</span></li>
          <li><span class="text-slate-400">White Rock, BC</span></li>
          <li><span class="text-slate-400">Langley, BC</span></li>
          <li><span class="text-slate-400">Burnaby, BC</span></li>
          <li><span class="text-slate-400">Delta, BC</span></li>
          <li><span class="text-slate-400">Richmond, BC</span></li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div
      class="border-t border-slate-800 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-slate-500"
    >
      <p>
        © {new Date().getFullYear()} Cleenly Services. All rights reserved.<br
          class="sm:hidden"
        />
        Licensed &amp; Insured in BC.
      </p>

      <div class="flex gap-6">
        <a href="#" class="hover:text-slate-300 transition-colors"
          >Privacy Policy</a
        >
        <a href="#" class="hover:text-slate-300 transition-colors"
          >Terms of Service</a
        >
      </div>
    </div>
  </div>
</footer>

---
import { getSiteMenu, getSiteSettings } from "@/lib/consts";
import { Phone } from "lucide-react";
const menu = await getSiteMenu();
const site = await getSiteSettings();
const formatPhone = (phone: string) => {
  const cleaned = phone.replace(/\D/g, "");
  return cleaned.replace(/^(\d{3})(\d{3})(\d{4})$/, "($1) $2-$3");
};
const formattedPhone = formatPhone(site.phone ? site.phone : "");
const SiteName = site.siteName.split(" ");
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-white"
>
  <div
    class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center justify-between h-16"
  >
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2">
      {
        site.logo?.url ? (
          <img src={site.logo.url} alt={site.siteName} class="w-5 h-5" />
        ) : (
          <span class="font-display text-xl font-semibold text-slate-900">
            {SiteName[0]} <span class="text-primary">{SiteName[1]}</span>
          </span>
        )
      }
    </a>
    <!-- Desktop Navigation -->
    <nav
      class="hidden md:flex items-center gap-8 text-sm font-medium text-slate-600"
    >
      {
        menu.items.map((item) => (
          <a
            href={item.href}
            target={item.newTab ? "_blank" : "_self"}
            class="hover:text-primary transition-colors"
          >
            {item.name}
          </a>
        ))
      }
    </nav>

    <!-- Right Side CTAs -->
    <div class="flex items-center gap-3">
      <a
        href={`tel:${site.phone}`}
        class="hidden sm:flex items-center gap-2 text-sm font-medium text-slate-700 hover:text-primary transition-colors"
      >
        <Phone size={16} />
        {formattedPhone}
      </a>

      <a
        href="#quote"
        class="bg-primary text-primary-foreground hover:bg-primary/90 transition-colors font-semibold text-sm px-6 py-2.5 rounded-2xl shadow-sm"
      >
        Get Instant Quote
      </a>
    </div>
  </div>
</header>

<script>
  const navbar = document.getElementById("navbar");
  function handleScroll() {
    if (!navbar) return;
    if (window.scrollY > 20) {
      navbar.classList.add("bg-white/95", "backdrop-blur-sm", "shadow-sm");
    } else {
      navbar.classList.remove("bg-white/95", "backdrop-blur-sm", "shadow-sm");
    }
  }
  window.addEventListener("scroll", handleScroll);
  // Initial check in case user refreshes while scrolled
  handleScroll();
</script>

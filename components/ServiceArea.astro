---
const areas = [
  { 
    name: 'Surrey', 
    desc: 'Including Newton, Fleetwood, Whalley, Cloverdale, and South Surrey' 
  },
  { 
    name: 'White Rock', 
    desc: 'All neighbourhoods in White Rock and Semiahmoo' 
  },
  { 
    name: 'Langley', 
    desc: 'Including Langley City, Willowbrook, Walnut Grove, and Fort Langley' 
  },
  { 
    name: 'Burnaby', 
    desc: 'Including Metrotown, Brentwood, and South Burnaby' 
  },
  { 
    name: 'Delta', 
    desc: 'Including North Delta, Ladner, and Tsawwassen' 
  },
  { 
    name: 'Richmond', 
    desc: 'Select areas of Richmond — contact us to confirm' 
  },
];
---

<section class="py-16 bg-slate-950">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <!-- Header -->
    <div class="text-center mb-12">
      <p class="text-primary font-semibold text-sm uppercase tracking-widest mb-3">
        Service Area
      </p>
      <h2 class="text-3xl md:text-4xl font-semibold text-white mb-4">
        We Come to You
      </h2>
      <p class="text-slate-400 max-w-xl mx-auto">
        Proudly serving the Fraser Valley and South Metro Vancouver area.
      </p>
    </div>

    <!-- Areas Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {areas.map((area) => (
        <div 
          class="flex items-start gap-4 bg-white/5 hover:bg-white/10 border border-white/10 rounded-2xl px-6 py-5 transition-all hover:border-primary/30 group"
        >
          <!-- Icon -->
          <div class="w-9 h-9 bg-primary rounded-xl flex items-center justify-center shrink-0 mt-0.5">
            <svg 
              width="18" 
              height="18" 
              viewBox="0 0 24 24" 
              fill="none" 
              stroke="currentColor" 
              stroke-width="2.5" 
              stroke-linecap="round" 
              stroke-linejoin="round"
            >
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </div>

          <!-- Text -->
          <div>
            <h3 class="font-semibold text-white text-lg mb-1">
              {area.name}
            </h3>
            <p class="text-slate-400 text-[15px] leading-snug">
              {area.desc}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- Footer Note -->
    <div class="mt-10 text-center">
      <p class="text-slate-400 text-sm">
        Not sure if we serve your area?{' '}
        <a 
          href="tel:+16045550192" 
          class="text-primary hover:text-primary/80 font-semibold underline underline-offset-4 transition-colors"
        >
          Give us a call
        </a>{' '}
        and we'll let you know.
      </p>
    </div>
  </div>
</section>